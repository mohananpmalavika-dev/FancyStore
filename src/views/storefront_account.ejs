<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="site">
    <header class="store-header">
      <a class="brand" href="/">
        <span class="brand-mark brand-logo" aria-hidden="true"></span>
        <span>The Golden Crown</span>
      </a>
      <nav class="site-nav" aria-label="Primary">
        <a href="/shop">Shop</a>
        <a href="/bag">Bag</a>
        <a href="/contact">Contact</a>
        <a href="/testimonials">Testimonials</a>
        <a href="/account">My store</a>
        <% if (currentUser && currentUser.role === 'admin') { %>
          <a href="/admin">Admin</a>
        <% } %>
      </nav>
      <div class="header-actions">
        <a class="icon-link" href="/bag" aria-label="Shopping bag">
          <span>Bag</span>
          <strong><%= cartCount %></strong>
        </a>
        <form method="post" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="button button-light" type="submit">Log out</button>
        </form>
      </div>
    </header>

    <main class="account-page">
      <section class="account-hero">
        <div>
          <h1>My Golden Crown</h1>
          <p>Orders, favorites, reminders, scheduled deliveries, and repeat purchases stay together here.</p>
        </div>
        <a class="button button-dark" href="/shop">Shop more</a>
      </section>

      <% if (notice) { %>
        <p class="notice-bar"><%= notice %></p>
      <% } %>

      <section class="account-grid">
        <div class="admin-panel">
          <div class="panel-header">
            <h2>Orders</h2>
          </div>
          <% if (!orders.length) { %>
            <div class="panel-empty">No orders yet.</div>
          <% } else { %>
            <table class="admin-table compact-table">
              <thead>
                <tr><th>Order</th><th>Status</th><th>Total</th><th>Placed</th></tr>
              </thead>
              <tbody>
                <% orders.forEach(order => { %>
                  <tr>
                    <td><a class="text-link" href="/orders/<%= order.id %>">#<%= order.id %></a></td>
                    <td><span class="status-pill status-<%= order.status || 'new' %>"><%= (order.status || 'new').replaceAll('_', ' ') %></span></td>
                    <td><%= formatRupees(order.total) %></td>
                    <td><%= order.created_at %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>

        <div class="admin-panel">
          <div class="panel-header">
            <h2>Favorites</h2>
          </div>
          <% if (!favorites.length) { %>
            <div class="panel-empty">No favorites saved.</div>
          <% } else { %>
            <div class="mini-product-list">
              <% favorites.forEach(product => { %>
                <article class="mini-product">
                  <div class="mini-product-image" style="--product-image: url('<%- product.image %>')"></div>
                  <div>
                    <strong><%= product.name %></strong>
                    <span><%= formatRupees(product.price) %></span>
                  </div>
                  <form method="post" action="/favorites/<%= product.id %>/remove">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="button button-light" type="submit">Remove</button>
                  </form>
                </article>
              <% }) %>
            </div>
          <% } %>
        </div>

        <div class="admin-panel">
          <div class="panel-header">
            <h2>Event reminders</h2>
          </div>
          <form class="admin-form compact-form" method="post" action="/account/events">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="two-fields">
              <label class="field">Type
                <select name="type">
                  <option value="birthday">Birthday</option>
                  <option value="anniversary">Anniversary</option>
                  <option value="spouse_birthday">Spouse birthday</option>
                  <option value="child_birthday">Child birthday</option>
                </select>
              </label>
              <label class="field">Date
                <input name="event_date" type="date" required />
              </label>
            </div>
            <div class="two-fields">
              <label class="field">Name
                <input name="name" />
              </label>
              <label class="field">Relation
                <input name="relation" />
              </label>
            </div>
            <button class="button button-dark" type="submit">Save reminder</button>
          </form>
          <% if (events.length) { %>
            <div class="simple-list">
              <% events.forEach(event => { %>
                <div>
                  <span><%= event.type.replaceAll('_', ' ') %> - <%= event.event_date %></span>
                  <form method="post" action="/account/events/<%= event.id %>/delete">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="text-button" type="submit">Delete</button>
                  </form>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <div class="admin-panel">
          <div class="panel-header">
            <h2>Scheduled deliveries</h2>
          </div>
          <% if (!scheduled.length) { %>
            <div class="panel-empty">No scheduled deliveries.</div>
          <% } else { %>
            <div class="simple-list">
              <% scheduled.forEach(row => { %>
                <div>
                  <span><strong><%= row.delivery_date %></strong> - <%= row.summary %></span>
                  <form method="post" action="/account/scheduled/<%= row.id %>/delete">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="text-button" type="submit">Delete</button>
                  </form>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <div class="admin-panel">
          <div class="panel-header">
            <h2>Recurring orders</h2>
          </div>
          <% if (!recurring.length) { %>
            <div class="panel-empty">No recurring orders.</div>
          <% } else { %>
            <div class="simple-list">
              <% recurring.forEach(row => { %>
                <div>
                  <span><strong><%= row.interval %></strong> from <%= row.next_run %> - <%= row.summary %></span>
                  <form method="post" action="/account/recurring/<%= row.id %>/delete">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="text-button" type="submit">Delete</button>
                  </form>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </section>
    </main>
    <%- include('partials/site_footer') %>
  </body>
</html>
