<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="admin-shell">
    <header class="admin-topbar">
      <a class="brand" href="/">
        <span class="brand-mark brand-logo" aria-hidden="true"></span>
        <span>The Golden Crown</span>
      </a>
      <nav class="admin-nav" aria-label="Admin">
        <a href="/admin/orders">Orders</a>
        <a href="/admin">Products</a>
        <a href="/admin/offers">Offers</a>
        <a href="/admin/recurring">Recurring</a>
        <a href="/admin/settings">Settings</a>
        <a href="/">Storefront</a>
      </nav>
    </header>

    <main class="admin-main">
      <section class="admin-hero">
        <div>
          <h1>Recurring Orders</h1>
          <p>Schedule repeat customer purchases and keep high-value gifting habits on track.</p>
        </div>
      </section>

      <section class="admin-panel">
        <div class="panel-header">
          <h2>Create recurring order</h2>
        </div>
        <form class="admin-form" method="post" action="/admin/recurring">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="admin-form-grid">
            <label class="field">User
              <select name="user_id">
                <% users.forEach(u => { %>
                  <option value="<%= u.id %>"><%= u.username %></option>
                <% }) %>
              </select>
            </label>
            <label class="field">Interval
              <select name="interval">
                <option value="weekly">weekly</option>
                <option value="monthly">monthly</option>
                <option value="bimonthly">bimonthly</option>
                <option value="quarterly">quarterly</option>
                <option value="halfyearly">halfyearly</option>
              </select>
            </label>
            <label class="field">Next run (ISO)
              <input name="next_run" value="<%= new Date().toISOString() %>" />
            </label>
          </div>
          <label class="field">Cart snapshot (JSON)
            <textarea name="cart_snapshot" rows="5">[{"product_id":1,"quantity":1}]</textarea>
          </label>
          <button class="button button-dark" type="submit">Create schedule</button>
        </form>
      </section>

      <section class="admin-panel" style="margin-top: 22px;">
        <div class="panel-header">
          <h2>Existing schedules</h2>
        </div>
        <table class="admin-table">
          <thead>
            <tr><th>ID</th><th>User</th><th>Interval</th><th>Next run</th><th>Action</th></tr>
          </thead>
          <tbody>
            <% rows.forEach(r => { %>
              <tr>
                <td>#<%= r.id %></td>
                <td><strong><%= r.username %></strong></td>
                <td><span class="status-pill"><%= r.interval %></span></td>
                <td><%= r.next_run %></td>
                <td>
                  <form method="post" action="/admin/recurring/<%= r.id %>/delete">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="button danger-button" type="submit">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    </main>
  </body>
</html>
